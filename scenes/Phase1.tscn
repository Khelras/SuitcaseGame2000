[node name="Wristwatch" parent="ItemManager" unique_id=40582580 groups=["items"] instance=ExtResource("2_uyvlg")]
position = Vector2(1011, 391)
texture = ExtResource("23_kloqn")
ItemSizeByCell = Vector2i(1, 4)
ItemName = "Wristwatch"
ItemDescription = "Your dad’s old watch, which he gifted to you on your 18th birthday. He was always crazy about watches, had a whole box case full of them. He said this is the kind of thing you pass down to your kids until it eventually becomes a family heirloom of sorts. It’s not there yet, but maybe one day."
Catagory = 3

[node name="EngravedAmulet" parent="ItemManager" unique_id=827017529 groups=["items"] instance=ExtResource("2_uyvlg")]
position = Vector2(994, 354)
texture = ExtResource("25_m1g8v")
ItemSizeByCell = Vector2i(1, 3)
ItemName = "EngravedAmulet"
ItemDescription = "A brass engraved amulet. Your family has had this since the 19th century if the stuff your grandpa told is to be believed. It's not worth much in terms of monetary value, but its sentimental value supersedes that fact."
Catagory = 1

