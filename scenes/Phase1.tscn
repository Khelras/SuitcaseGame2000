[node name="PhotoOfAuntieSuze" parent="ItemManager" unique_id=93316893 groups=["items"] instance=ExtResource("2_uyvlg")]
position = Vector2(910, 286)
scale = Vector2(0.774, 0.774)
texture = ExtResource("4_khfs5")
ItemSizeByCell = Vector2i(4, 4)
ItemName = "photo of Auntie Suze"
ItemDescription = "it's funny how in times like these, people
fall out of your life. You remember how
she’d take care of you when your mother
was out. Her smile in the photo is warm
and familiar. Whatever happened to her,
you can't say, but it would mean the
world to your dad if you took this with you.  "
Catagory = 1

[node name="PhotoBday" parent="ItemManager" unique_id=1849605442 groups=["items"] instance=ExtResource("2_uyvlg")]
position = Vector2(865.00006, 485)
scale = Vector2(0.79, 0.774)
texture = ExtResource("5_424rd")
ItemSizeByCell = Vector2i(4, 4)
ItemName = "BirthdayPhoto"
ItemDescription = "Damn, this thing is old, a photo of you on
your 3rd birthday. Mum has been looking
all over for this. A deep sense of
unfairness runs through you. The smile
on your mum's face in the photo is
something you haven't seen in a while.
The clueless look on your face makes
you smirk a little. "

[node name="Book" parent="ItemManager" unique_id=1571515905 groups=["items"] instance=ExtResource("2_uyvlg")]
position = Vector2(939, 344)
texture = ExtResource("8_57w61")
ItemSizeByCell = Vector2i(3, 4)
ItemName = "Book"
ItemDescription = "Your favourite novel, gifted to you by your mum. Knowing how much you liked the fantasy books she used to read you when you were younger, she gave this to you on your 8th birthday. You were enamored with it for the months afterwards. Looking at it makes you remember all those times you’d pretend to be the piper or the leviathan and play with your schoolmates or cousins."
Catagory = 1

